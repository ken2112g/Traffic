# Redis (BullMQ cần Redis để chạy queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Database (thư mục data/ tự tạo khi khởi động)
DB_PATH=./data/traffic.db

# Sessions (thư mục sessions/ tự tạo khi khởi động)
SESSION_DIR=./sessions

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Số browser chạy song song tối đa
MAX_CONCURRENT_BROWSERS=5

# Dashboard port (mặc định 3100)
UI_PORT=3100

# Browser mode: "false" = hiển thị cửa sổ (dùng để debug), "true" = ẩn (production)
HEADLESS=true

# Telegram alerts (tùy chọn — để trống nếu không dùng)
# Tạo bot: https://t.me/BotFather → /newbot
# Lấy chat_id: gửi tin nhắn cho bot rồi vào https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard basic auth (tùy chọn — để trống nếu không cần đăng nhập)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=